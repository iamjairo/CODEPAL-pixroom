{
  "name": "@codepalaiorg/pinpoint",
  "version": "0.2.4",
  "description": "Policy-controlled MCP dataflow for AI agents, with exact local projections and signed receipts.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "Apache-2.0",
  "author": {
    "name": "CodePal",
    "url": "https://codepal.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodePalAI/pinpoint.git"
  },
  "homepage": "https://github.com/CodePalAI/pinpoint#readme",
  "bugs": {
    "url": "https://github.com/CodePalAI/pinpoint/issues"
  },
  "bin": {
    "pinpoint": "bin/cli.js",
    "pinpoint-verify-receipt": "bin/verify-receipt.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./anthropic": {
      "types": "./dist/sdk/anthropic.d.ts",
      "import": "./dist/sdk/anthropic.js"
    },
    "./openai": {
      "types": "./dist/sdk/openai.d.ts",
      "import": "./dist/sdk/openai.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./proxy": {
      "types": "./dist/proxy/server.d.ts",
      "import": "./dist/proxy/server.js"
    },
    "./router": {
      "types": "./dist/router/content-router.d.ts",
      "import": "./dist/router/content-router.js"
    },
    "./kernel": {
      "types": "./dist/kernel/index.d.ts",
      "import": "./dist/kernel/index.js"
    },
    "./protocols": {
      "types": "./dist/protocols/index.d.ts",
      "import": "./dist/protocols/index.js"
    },
    "./output": {
      "types": "./dist/output/index.d.ts",
      "import": "./dist/output/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "import": "./dist/agents/index.js"
    },
    "./virtual-context": {
      "types": "./dist/virtual-context/index.d.ts",
      "import": "./dist/virtual-context/index.js"
    },
    "./capture": {
      "types": "./dist/capture/index.d.ts",
      "import": "./dist/capture/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./dashboard": {
      "types": "./dist/dashboard/index.d.ts",
      "import": "./dist/dashboard/index.js"
    }
  },
  "files": [
    "assets/",
    "comparisons/",
    "benchmarks/REPORT.md",
    "benchmarks/REPRODUCING.md",
    "benchmarks/results/mcp-gateway-agent.first-party-macos-arm64-20260715.json",
    "benchmarks/results/mcp-gateway-cross-host.first-party-macos-arm64-20260715.json",
    "benchmarks/results/mcp-opaque-flow.first-party-macos-arm64-20260715.json",
    "benchmarks/results/mcp-opaque-flow-cross-host.first-party-macos-arm64-20260715.json",
    "benchmarks/results/opaque-flow-model-check.first-party-macos-arm64-20260715.json",
    "benchmarks/results/opaque-flow-async-model-check.first-party-macos-arm64-20260719.json",
    "benchmarks/results/mcp-oss-filesystem.first-party-macos-arm64-20260715.json",
    "benchmarks/results/mcp-oss-cross-server.first-party-macos-arm64-20260716.json",
    "benchmarks/results/mcp-common-workflows.first-party-macos-arm64-20260716.json",
    "benchmarks/results/hcp-comparison.first-party-macos-arm64-20260716.json",
    "benchmarks/competitors/hcp_same_workflow_adapter.mjs",
    "benchmarks/v2/hcp_comparison_gate.mjs",
    "bin/",
    "dist/",
    "examples/",
    "!dist/**/*.map",
    "planning/product_assessment.md",
    "planning/query_backed_context.md",
    "planning/mcp_result_firewall.md",
    "planning/value_opaque_mcp_dataflow.md",
    "planning/opaque_flow_formal_properties.md",
    "planning/breakthrough_scorecard.md",
    "planning/common_mcp_workflow_evaluation.md",
    "planning/dashboard.md",
    "formal/opaque_flow.pml",
    "formal/opaque_flow_async.pml",
    "README.md",
    "RELEASING.md",
    "llms.txt",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "MAINTAINERS.md",
    "SECURITY.md",
    "UPSTREAM.md",
    "NOTICE",
    "THIRD_PARTY_NOTICES.md",
    "LICENSE"
  ],
  "scripts": {
    "assets:readme": "node scripts/render-readme-assets.mjs",
    "docs:check": "node scripts/check-readme.mjs",
    "package:manifest-check": "node scripts/check-package-manifest.mjs",
    "formal:opaque-flow": "node scripts/check-opaque-flow-model.mjs",
    "formal:opaque-flow:mutation": "node scripts/check-opaque-flow-model-mutation.mjs",
    "formal:opaque-flow:async": "node scripts/check-opaque-flow-async-model.mjs",
    "package:smoke": "node scripts/smoke-package.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:dashboard": "vite build --config vite.dashboard.config.ts",
    "build": "npm run clean && tsc -p tsconfig.json && npm run build:dashboard",
    "prepare": "npm run build",
    "typecheck:dashboard": "tsc -p tsconfig.dashboard.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && npm run typecheck:dashboard",
    "release:check": "node scripts/check-release.mjs",
    "licenses:check": "node scripts/check-licenses.mjs",
    "sbom": "node scripts/generate-sbom.mjs",
    "supply-chain:check": "npm run licenses:check && npm audit --audit-level=high && npm audit signatures",
    "verify": "npm run package:manifest-check && npm run release:check && npm run supply-chain:check && npm run docs:check && npm run typecheck && npm test && npm run build && npm run package:smoke",
    "verify:release": "npm run assets:readme && npm run verify",
    "dev": "tsx src/cli/main.ts",
    "demo:qcv": "npm run build && node bin/cli.js demo",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:dashboard:e2e": "npm run build && playwright test --config playwright.dashboard.config.ts",
    "test:mcp-adversarial": "vitest run tests/mcp-gateway.test.ts tests/mcp-cross-server.test.ts tests/mcp-destination.test.ts tests/mcp-opaque-flow-properties.test.ts",
    "test:watch": "vitest",
    "bench:profile": "npm run build && node benchmarks/v2/profile_proxy.mjs",
    "bench:profile:isolated": "npm run build && node benchmarks/v2/profile_proxy_isolated.mjs",
    "bench:virtual": "npm run build && node benchmarks/virtual_context.mjs",
    "bench:qcv-quality": "npm run build && node benchmarks/qcv_quality.mjs",
    "bench:anthropic:self-test": "npm run build && node benchmarks/v2/direct_anthropic.mjs --phase self-test",
    "bench:anthropic:preflight": "npm run build && node benchmarks/v2/direct_anthropic.mjs --phase preflight",
    "bench:anthropic:canary": "npm run build && node benchmarks/v2/direct_anthropic.mjs --phase canary",
    "bench:anthropic": "npm run build && node benchmarks/v2/direct_anthropic.mjs --phase benchmark",
    "bench:evidence:self-test": "npm run build && node benchmarks/v2/evidence_gate.mjs --phase self-test",
    "bench:evidence:preflight": "npm run build && node benchmarks/v2/evidence_gate.mjs --phase preflight",
    "bench:evidence:canary": "npm run build && node benchmarks/v2/evidence_gate.mjs --phase canary",
    "bench:evidence": "npm run build && node benchmarks/v2/evidence_gate.mjs --phase benchmark",
    "bench:agent-traces:canary": "npm run build && node benchmarks/v2/agent_trace_gate.mjs --phase canary",
    "bench:agent-traces": "npm run build && node benchmarks/v2/agent_trace_gate.mjs --phase benchmark",
    "bench:mcp-gateway:agent": "npm run build && node benchmarks/v2/mcp_gateway_agent_gate.mjs",
    "bench:mcp-gateway:copilot": "npm run build && node benchmarks/v2/mcp_gateway_copilot_gate.mjs",
    "bench:mcp-opaque-flow": "npm run build && node benchmarks/v2/mcp_opaque_flow_gate.mjs",
    "bench:mcp-opaque-flow:cross-host": "npm run build && node benchmarks/v2/mcp_opaque_flow_cross_host_gate.mjs",
    "bench:mcp-oss-filesystem": "npm run build && node benchmarks/v2/mcp_oss_filesystem_gate.mjs",
    "bench:mcp-oss-cross-server": "npm run build && node benchmarks/v2/mcp_oss_cross_server_gate.mjs",
    "bench:mcp-common-workflows": "npm run build && node benchmarks/v2/mcp_common_workflows_gate.mjs",
    "bench:compare-hcp": "npm run build && node benchmarks/v2/hcp_comparison_gate.mjs",
    "prepublishOnly": "npm run verify:release"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "llm",
    "mcp",
    "mcp-security",
    "ai-security",
    "agent-security",
    "data-governance",
    "privacy",
    "context-virtualization",
    "mcp-gateway",
    "mcp-proxy",
    "mcp-dataflow",
    "privacy-preserving",
    "query-backed-context",
    "claude-code",
    "github-copilot",
    "anthropic",
    "openai",
    "proxy",
    "agent-runtime",
    "plugin-system",
    "opentelemetry",
    "pxpipe",
    "headroom",
    "codepal"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "pxpipe-proxy": "0.8.0"
  },
  "devDependencies": {
    "@fontsource-variable/instrument-sans": "^5.2.8",
    "@playwright/test": "1.61.1",
    "@types/node": "^22.10.0",
    "ajv": "^8.17.1",
    "lucide": "^1.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
