{
  "name": "@codepal/pinpoint",
  "version": "0.1.0",
  "description": "CodePal's open-source LLM context optimizer for reducing repeated input while preserving exact tool data.",
  "type": "module",
  "license": "Apache-2.0",
  "author": {
    "name": "CodePal",
    "url": "https://codepal.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodePalAI/pinpoint.git"
  },
  "homepage": "https://github.com/CodePalAI/pinpoint#readme",
  "bugs": {
    "url": "https://github.com/CodePalAI/pinpoint/issues"
  },
  "bin": {
    "pinpoint": "bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./anthropic": {
      "types": "./dist/sdk/anthropic.d.ts",
      "import": "./dist/sdk/anthropic.js"
    },
    "./openai": {
      "types": "./dist/sdk/openai.d.ts",
      "import": "./dist/sdk/openai.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./proxy": {
      "types": "./dist/proxy/server.d.ts",
      "import": "./dist/proxy/server.js"
    },
    "./router": {
      "types": "./dist/router/content-router.d.ts",
      "import": "./dist/router/content-router.js"
    },
    "./kernel": {
      "types": "./dist/kernel/index.d.ts",
      "import": "./dist/kernel/index.js"
    },
    "./protocols": {
      "types": "./dist/protocols/index.d.ts",
      "import": "./dist/protocols/index.js"
    },
    "./output": {
      "types": "./dist/output/index.d.ts",
      "import": "./dist/output/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "import": "./dist/agents/index.js"
    },
    "./virtual-context": {
      "types": "./dist/virtual-context/index.d.ts",
      "import": "./dist/virtual-context/index.js"
    },
    "./capture": {
      "types": "./dist/capture/index.d.ts",
      "import": "./dist/capture/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.js"
    }
  },
  "files": [
    "assets/",
    "benchmarks/REPORT.md",
    "benchmarks/REPRODUCING.md",
    "benchmarks/results/direct-anthropic-virtual.json",
    "bin/",
    "dist/",
    "examples/",
    "!dist/**/*.map",
    "planning/product_assessment.md",
    "planning/query_backed_context.md",
    "README.md",
    "llms.txt",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "UPSTREAM.md",
    "NOTICE",
    "LICENSE"
  ],
  "scripts": {
    "assets:readme": "node scripts/render-readme-assets.mjs",
    "docs:check": "node scripts/check-readme.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli/main.ts",
    "demo:qcv": "npm run build && node bin/cli.js demo",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:profile": "npm run build && node benchmarks/v2/profile_proxy.mjs",
    "bench:profile:isolated": "npm run build && node benchmarks/v2/profile_proxy_isolated.mjs",
    "bench:virtual": "npm run build && node benchmarks/virtual_context.mjs",
    "bench:qcv-quality": "npm run build && node benchmarks/qcv_quality.mjs",
    "bench:anthropic:self-test": "npm run build && node benchmarks/v2/direct_anthropic.mjs --phase self-test",
    "bench:anthropic:preflight": "npm run build && node benchmarks/v2/direct_anthropic.mjs --phase preflight",
    "bench:anthropic:canary": "npm run build && node benchmarks/v2/direct_anthropic.mjs --phase canary",
    "bench:anthropic": "npm run build && node benchmarks/v2/direct_anthropic.mjs --phase benchmark",
    "prepublishOnly": "npm run assets:readme && npm run docs:check && npm run typecheck && npm test && npm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "llm",
    "context-compression",
    "context-virtualization",
    "query-backed-context",
    "token-optimization",
    "prompt-cache",
    "claude-code",
    "anthropic",
    "openai",
    "proxy",
    "agent-runtime",
    "plugin-system",
    "opentelemetry",
    "pxpipe",
    "headroom",
    "codepal"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "pxpipe-proxy": "0.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
