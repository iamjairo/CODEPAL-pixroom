{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CodePalAI/pinpoint/blob/main/examples/mcp-opaque-flow.schema.json",
  "title": "Pinpoint opaque MCP flow configuration v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "flows"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "exposeQueryTool": {
      "type": "boolean",
      "default": false
    },
    "exposeArtifactResources": {
      "type": "boolean",
      "default": false
    },
    "opaqueArtifactIds": {
      "type": "boolean",
      "default": true
    },
    "flows": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/flow"
      }
    }
  },
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]{0,127}$"
    },
    "uniqueNames": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/name"
      }
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "sourceTool",
        "destinationTool",
        "destinationArgument",
        "allowedOps"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{0,63}$"
        },
        "description": {
          "type": "string",
          "maxLength": 512
        },
        "sourceTool": {
          "$ref": "#/$defs/name"
        },
        "sourceKind": {
          "enum": [
            "json-array",
            "json-object",
            "lines"
          ]
        },
        "destinationTool": {
          "$ref": "#/$defs/name"
        },
        "destinationArgument": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]{0,127}$"
        },
        "fixedDestinationArguments": {
          "type": "object"
        },
        "allowedDestinationArguments": {
          "$ref": "#/$defs/uniqueNames"
        },
        "allowedOps": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "json_select",
              "count",
              "grep",
              "slice"
            ]
          }
        },
        "fixedWhere": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 16,
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_.-]{0,127}$"
          },
          "additionalProperties": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" },
              { "type": "null" }
            ]
          }
        },
        "allowedWhereFields": {
          "$ref": "#/$defs/uniqueNames"
        },
        "allowedFields": {
          "$ref": "#/$defs/uniqueNames"
        },
        "maxItems": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 100
        },
        "maxBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10485760,
          "default": 65536
        },
        "maxDestinationArgumentBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576,
          "default": 16384
        },
        "hideDestinationTool": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}